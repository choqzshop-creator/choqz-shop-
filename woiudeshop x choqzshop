<script>
function buatLink(){
  const uid=document.getElementById('uid').value.trim();
  const nominal=document.getElementById('nominal').value.trim();
  const bayar=document.getElementById('bayar').value;
  const voucher=document.getElementById('voucher').value.trim();
  if(!uid||!nominal){alert('ID & nominal wajib');return;}
  let txt=`Order ChoqzShop%0AID: ${uid}%0ANominal: ${nominal}%0ABayar: ${bayar}`;
  if(voucher) txt+=`%0AVoucher: ${voucher}`;
  const link=`https://wa.me/6283126088118?text=${txt}`;
  document.getElementById('out').innerHTML=`<a href="${link}" target="_blank">Buka WhatsApp & kirim order</a>`;
}
</script>
